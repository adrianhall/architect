#############################################################################
#
# CLOUDFLARE ARCHITECT — ENVIRONMENT VARIABLES
#
# Copy this file to .env and fill in your values before running
# `npm run provision`. All five variables below are required; Terraform
# reads them from this file via the `dotenv` provider.
#
# NEVER commit .env to version control. It is listed in .gitignore.
#
#############################################################################

#############################################################################
#
# CLOUDFLARE ACCOUNT SETTINGS
#
# These two variables authenticate Terraform and Wrangler against your
# Cloudflare account.  Create an Account API Token (not a User API Token)
# with the following permissions:
#
#   Category                               Permission
#   ────────────────────────────────────────────────────────────────────────
#   Developer Platform → D1                Edit
#   Developer Platform → Workers Scripts   Edit
#   Developer Platform → Workers Tail      Read
#   Cloudflare One / Zero Trust → Access   Edit
#
# How to create the token:
#   Dashboard → My Profile → API Tokens → Create Token → Custom Token
#
# CLOUDFLARE_ACCOUNT_ID:
#   Your 32-character hex account ID.  Found on the right-hand side of:
#   Dashboard → Workers & Pages → Overview (under "Account Details")
#
# CLOUDFLARE_API_TOKEN:
#   The newly created Account API Token value.  Shown only once at creation.
#   Starts with "cfat_" followed by a hex string.
#
CLOUDFLARE_ACCOUNT_ID="{your-account-id}"
CLOUDFLARE_API_TOKEN="cfat_{your-api-token}"

#############################################################################
#
# CLOUDFLARE WORKERS DOMAIN
#
# CLOUDFLARE_WORKERS_DOMAIN:
#   Your account's workers.dev subdomain.  Every Worker you deploy is
#   accessible at: https://<worker-name>.<workers-domain>
#
#   Found in: Dashboard → Workers & Pages → Overview → Account Details
#   Format:   {something}.workers.dev
#
CLOUDFLARE_WORKERS_DOMAIN="{your-workers-domain}.workers.dev"
# Worker name (used in Terraform and wrangler config)
TF_VAR_worker_name=cf-architect

#############################################################################
#
# CLOUDFLARE ZERO TRUST SETTINGS
#
# These two variables configure the Cloudflare Access application that
# protects the Worker.  Terraform creates the Access policy and application
# automatically; you only need to provide the identifiers below.
#
# CLOUDFLARE_TEAM_DOMAIN:
#   Your Cloudflare Zero Trust organization domain.
#   Found in: Zero Trust Dashboard → Settings → Team domain
#   Format:   {your-org}.cloudflareaccess.com
#
# CLOUDFLARE_IDP_ID:
#   The UUID of the identity provider (IdP) configured in your Zero Trust
#   organization.  Terraform uses this ID to set the "allowed_idps" on the
#   Access application so only users from your IdP can authenticate.
#
#   Found in: Zero Trust Dashboard → Integrations → Identity Providers → {your-IdP} 
#             (copy the ID from the URL)
#   Format:   xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx (UUID)
#
CLOUDFLARE_TEAM_DOMAIN="{your-team-domain}.cloudflareaccess.com"
CLOUDFLARE_IDP_ID="{your-idp-id}"

#############################################################################
#
# APPLICATION SETTINGS
# 
# SEED_ADMIN_EMAIL - the email address of the first admin user.
#
SEED_ADMIN_EMAIL=

